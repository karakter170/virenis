# Run this file on the separate web server. The SSH tunnel maps this web
# server's loopback port 19000 to TCAR's loopback port 9000 on the GPU server.
NODE_ENV=production
HOST=127.0.0.1
PORT=5173
WEB_DATA_DIR=/var/lib/tcar-web-data
WEB_UPLOAD_DIR=/var/lib/tcar-web-uploads
APP_PUBLIC_ORIGIN=https://web.example.com
APP_TRUST_PROXY=loopback
APP_ALLOW_PUBLIC_BIND=0
APP_ALLOW_MISSING_PUBLIC_ORIGIN=0
APP_ALLOW_MISSING_ORIGIN=0
APP_ALLOW_SAME_SITE_FETCH=0
APP_ENABLE_HSTS=1

# Clerk browser identity. Replace every web.example.com occurrence with the
# exact canonical HTTPS browser origin. Build with `npm run build:remote` so the
# frontend and backend use this same publishable key. Keep secret values in
# mode-0600 files on the web host.
APP_IDENTITY_PROVIDER=clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_live_replace-with-clerk-publishable-key
CLERK_PUBLISHABLE_KEY=pk_live_replace-with-clerk-publishable-key
CLERK_SECRET_KEY=
CLERK_SECRET_KEY_FILE=/home/ubuntu/.config/virenis/clerk_secret_key
CLERK_WEBHOOK_SIGNING_SECRET=
CLERK_WEBHOOK_SIGNING_SECRET_FILE=/home/ubuntu/.config/virenis/clerk_webhook_signing_secret
CLERK_AUTHORIZED_PARTIES=https://web.example.com
APP_AUTH_ADMIN_EMAILS=admin@your-domain.example
APP_CLERK_ADMIN_USER_IDS=

APP_BACKGROUND_DRAIN_TIMEOUT_MS=930000
APP_ACCOUNT_DELETION_DRAIN_TIMEOUT_MS=5000
APP_ACCOUNT_DELETION_RECOVERY_INTERVAL_MS=60000
APP_ACCOUNT_DELETION_RECOVERY_BATCH=25
APP_SHUTDOWN_TIMEOUT_MS=960000
# Loopback Postgres is exempt from the remote-TLS requirement. If this points
# to another host, append ?sslmode=verify-full.
DATABASE_URL=postgres://virenis_web:replace-with-password@127.0.0.1:5432/tcar_app
WEB_ALLOW_INSECURE_PRIVATE_POSTGRES=0
WEB_STORE_DRIVER=postgres
WEB_DB_TABLE=tcar_app_store
WEB_DB_STORE_KEY=production
WEB_DB_READINESS_TIMEOUT_MS=5000
WEB_DB_CONNECT_TIMEOUT_MS=5000
# PostgreSQL cancels slightly before this client-side fail-safe deadline.
WEB_DB_QUERY_TIMEOUT_MS=5000
WEB_NORMALIZED_LEDGER_REQUIRED=1
WEB_NORMALIZED_BILLING_REQUIRED=1
TCAR_PREFLIGHT_CURL_CONNECT_TIMEOUT_SEC=5
TCAR_PREFLIGHT_CURL_MAX_TIME_SEC=15
APP_MAX_ACTIVE_RUNS_PER_USER=2
APP_MAX_ACTIVE_RUNS_PER_WORKSPACE=8
APP_MAX_ACTIVE_RUNS_GLOBAL=16

# Do not put VLLM_BASE_URL or VLLM_API_KEY on the web server. The backend calls
# TCAR, and TCAR calls vLLM inside the GPU server.
TCAR_ENGINE_MODE=real
TCAR_RUNTIME_API_URL=http://127.0.0.1:19000
TCAR_RUNTIME_API_KEY=
TCAR_RUNTIME_API_KEY_FILE=/home/ubuntu/.config/virenis/tcar_runtime_api_key
TCAR_ALLOW_LOOPBACK_RUNTIME_TUNNEL=1
TCAR_ALLOW_LOCAL_RUNTIME_URL=0
TCAR_ALLOW_SAME_ORIGIN_RUNTIME_URL=0
TCAR_ALLOW_INSECURE_PRIVATE_RUNTIME_HTTP=0
TCAR_RUNTIME_HEALTH_TIMEOUT_MS=5000
TCAR_RUNTIME_AGENT_LIST_TIMEOUT_MS=120000
TCAR_RUNTIME_CHAT_TIMEOUT_MS=900000
TCAR_RUNTIME_TERMINAL_RECOVERY_MS=90000
TCAR_RUNTIME_WORKFLOW_TIMEOUT_MS=900000
TCAR_RUNTIME_CONTINUATION_TIMEOUT_MS=900000
TCAR_RUNTIME_ADMIN_TIMEOUT_MS=600000
TCAR_RUNTIME_VALIDATION_TIMEOUT_SEC=900

# Keep both files mode 0600. The gateway key must match TCAR_MCP_GATEWAY_KEY on
# the GPU Runtime host. The credential key never leaves the web host.
APP_MCP_CREDENTIAL_KEY=
APP_MCP_CREDENTIAL_KEY_FILE=/home/ubuntu/.config/virenis/mcp_credential_key
APP_MCP_GATEWAY_KEY=
APP_MCP_GATEWAY_KEY_FILE=/home/ubuntu/.config/virenis/mcp_gateway_key
APP_MCP_TIMEOUT_MS=15000
APP_MCP_DNS_TIMEOUT_MS=5000
# Register the Google callback paths for gmail, google_drive, google_calendar,
# google_chat, and google_contacts under this exact HTTPS origin.
APP_MCP_OAUTH_REDIRECT_ORIGIN=https://web.example.com
APP_MCP_OAUTH_TIMEOUT_MS=15000
APP_MCP_OAUTH_RECOVERY_GRACE_MS=1200000
APP_MCP_OAUTH_RECOVERY_INTERVAL_MS=60000
APP_MCP_OAUTH_RECOVERY_BATCH=25
WORKFLOW_CONTINUATION_CLAIM_TTL_MS=930000
APP_MCP_GOOGLE_OAUTH_CLIENT_ID=
APP_MCP_GOOGLE_OAUTH_CLIENT_SECRET=
APP_MCP_GOOGLE_OAUTH_CLIENT_SECRET_FILE=
# Legacy Gmail-only credentials remain accepted during migration.
APP_MCP_GMAIL_OAUTH_CLIENT_ID=
APP_MCP_GMAIL_OAUTH_CLIENT_SECRET=
APP_MCP_GMAIL_OAUTH_CLIENT_SECRET_FILE=
APP_MCP_GITHUB_OAUTH_CLIENT_ID=
APP_MCP_GITHUB_OAUTH_CLIENT_SECRET=
APP_MCP_GITHUB_OAUTH_CLIENT_SECRET_FILE=
APP_MCP_SLACK_OAUTH_CLIENT_ID=
APP_MCP_SLACK_OAUTH_CLIENT_SECRET=
APP_MCP_SLACK_OAUTH_CLIENT_SECRET_FILE=

TCAR_PLANNER_MODE=session
TCAR_PLANNER_MAX_TOKENS=768
TCAR_MAX_ROUTING_ADAPTERS=16
TCAR_PARALLEL_WORKERS=2
TCAR_MAX_TOKENS=4096
TCAR_REFINER_MAX_TOKENS=8192
TCAR_TEMPERATURE=0
TCAR_CLIENT_MAX_PLANNER_TOKENS=4096
TCAR_CLIENT_MAX_ROUTING_ADAPTERS=16
TCAR_CLIENT_MAX_PARALLEL_WORKERS=4
TCAR_CLIENT_MAX_TOKENS=8192
TCAR_CLIENT_MAX_REFINER_TOKENS=12288
TCAR_CLIENT_MAX_TEMPERATURE=1
# These must match the worker and Router API deployments. The application uses
# them to keep output settings from consuming the prompt/handoff context.
TCAR_MODEL_CONTEXT_TOKENS=32768
ROUTER_SESSION_CONTEXT_TOKENS=32768
TCAR_ROUTE_INPUT_MAX_TOKENS=8192
TCAR_REFINER_INPUT_MAX_TOKENS=16384
TCAR_ROUTE_MIN_INPUT_TOKENS=8192
TCAR_REFINER_MIN_INPUT_TOKENS=16384
TCAR_ROUTE_TOKEN_SAFETY_MARGIN=128
TCAR_COMPLETION_TOKEN_SAFETY_MARGIN=192
TCAR_COMPACT_ROUTE_PROMPTS=1
TCAR_SKILL_PROMPT_MAX_CHARS=2000
TCAR_SOURCE_PROMPT_MAX_CHARS=6000
TCAR_RETRIEVED_CONTEXT_MAX_CHARS=12000

APP_BASIC_AUTH_USER=admin
APP_BASIC_AUTH_PASSWORD=
# tcar-web-tunneled.service creates this private persistent directory before
# applying ProtectHome/ReadWritePaths, so first-start generation is sandbox-safe.
APP_BASIC_AUTH_PASSWORD_FILE=/var/lib/tcar-web-secrets/web_basic_auth_password
APP_GENERATE_BASIC_AUTH_PASSWORD=1
APP_DEFAULT_WORKSPACE_ID=workspace_default
APP_ALLOW_UNAUTHENTICATED=0
APP_ALLOW_JSON_STORE=0

API_RATE_WINDOW_MS=60000
API_RATE_LIMIT=600
API_RATE_MAX_BUCKETS=10000
# Bound long-lived run-event connections separately from ordinary API calls.
# The 16-minute lifetime covers the configured 15-minute Runtime budget while
# guaranteeing cleanup of abandoned browser streams.
APP_SSE_MAX_STREAMS_GLOBAL=500
APP_SSE_MAX_STREAMS_PER_IDENTITY=8
APP_SSE_HEARTBEAT_MS=15000
APP_SSE_MAX_LIFETIME_MS=960000
WEB_LIST_DEFAULT_LIMIT=100
WEB_LIST_MAX_LIMIT=500
WEB_READY_REQUIRE_RUNTIME=1
WEB_READY_INCLUDE_STORE_COUNTS=0
TCAR_WEB_READY_URL=http://127.0.0.1:5173/readyz
APP_MAX_JSON_BODY_BYTES=1048576
APP_MAX_UPLOAD_FILE_BYTES=15728640
APP_MAX_UPLOAD_FIELD_BYTES=65536
APP_MAX_UPLOAD_FIELDS=20
APP_MAX_UPLOAD_PARTS=24
APP_MAX_DOCUMENT_TEXT_CHARS=2000000
APP_MAX_DOCUMENT_PDF_PAGES=500
APP_PDF_EXTRACTION_TIMEOUT_MS=60000
APP_MAX_DOCUMENT_CHUNKS=1000
APP_MAX_DOCUMENTS_PER_USER=50
APP_MAX_DOCUMENTS_PER_WORKSPACE=200
APP_MAX_SOURCE_TEXT_CHARS=200000
APP_MAX_MESSAGE_ATTACHMENTS=5
APP_MAX_MESSAGE_ATTACHMENT_CHARS=2000
TCAR_SHARED_MEMORY_MAX_ENTRIES=40
TCAR_SHARED_MEMORY_MAX_ENTRY_CHARS=2000
TCAR_SHARED_MEMORY_MAX_TOTAL_CHARS=20000

# SSH transport from the web server to this GPU server.
GPU_SSH_HOST=216.81.200.239
GPU_SSH_PORT=32338
GPU_SSH_USER=ubuntu
GPU_SSH_IDENTITY_FILE=/home/ubuntu/.ssh/tcar_gpu
GPU_SSH_KNOWN_HOSTS_FILE=/home/ubuntu/.ssh/known_hosts
TCAR_TUNNEL_LOCAL_HOST=127.0.0.1
TCAR_TUNNEL_LOCAL_PORT=19000
TCAR_TUNNEL_RUNTIME_HOST=127.0.0.1
TCAR_TUNNEL_RUNTIME_PORT=9000
