# SSH-forwarding settings for the dedicated virenis-tunnel service account.
# Install the completed file as /etc/virenis/runtime-tunnel.env. Do not add web,
# database, Clerk, Agent Runtime API, MCP, or application credentials here.
AGENT_RUNTIME_SSH_BINARY=/usr/bin/ssh
AGENT_RUNTIME_SSH_HOST=gpu-runtime.example.com
AGENT_RUNTIME_SSH_PORT=22
AGENT_RUNTIME_SSH_USER=virenis-runtime-tunnel
AGENT_RUNTIME_SSH_IDENTITY_FILE=/etc/virenis/runtime-tunnel/id_ed25519
AGENT_RUNTIME_SSH_KNOWN_HOSTS_FILE=/etc/virenis/runtime-tunnel/known_hosts
AGENT_RUNTIME_TUNNEL_LOCAL_HOST=127.0.0.1
AGENT_RUNTIME_TUNNEL_LOCAL_PORT=19000
AGENT_RUNTIME_TUNNEL_RUNTIME_HOST=127.0.0.1
AGENT_RUNTIME_TUNNEL_RUNTIME_PORT=9000
