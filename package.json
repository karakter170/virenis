{
  "name": "tcar-agent-router-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server/index.js",
    "dev:tcar": "node --env-file-if-exists=.env.local server/index.js",
    "dev:vllm": "node --env-file-if-exists=.env.local server/index.js",
    "runtime:vllm": "node --env-file-if-exists=.env.local server/vllmRuntimeAdapter.js",
    "start": "NODE_ENV=production node server/index.js",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.9.0",
    "supertest": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
