{
  "name": "virenis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.20.2",
    "npm": "10.8.2"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.runtime.local server/index.js",
    "dev:runtime": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.runtime.local server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "start:hosted": "NODE_ENV=production node server/hostedStart.js",
    "start:remote": "NODE_ENV=production node --env-file=.env.remote.local server/hostedStart.js",
    "tunnel:runtime": "node --env-file=.env.runtime-tunnel.local scripts/runtimeTunnel.mjs",
    "preflight:remote": "NODE_ENV=production node --env-file=.env.remote.local scripts/remotePreflight.mjs",
    "preflight:auth": "node --env-file-if-exists=.env.local scripts/clerkOriginPreflight.mjs",
    "preflight:auth:remote": "NODE_ENV=production node --env-file=.env.remote.local scripts/clerkOriginPreflight.mjs",
    "build": "vite build",
    "build:remote": "NODE_ENV=production node --env-file=.env.remote.local ./node_modules/vite/bin/vite.js build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:clerk:postgres": "node scripts/clerk_postgres_smoke.mjs",
    "test:watch": "vitest",
    "lint": "eslint .",
    "marketing:router-quality": "node marketing/router-quality-showcase/render.mjs",
    "marketing:qwen-comparison:test": "node scripts/test_complex_team_comparison_ui.mjs",
    "test:live:agent-builder": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.runtime.local scripts/test_agent_builder_ui_live.mjs",
    "test:live:discover-isolation": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.runtime.local scripts/test_discover_team_isolation_ui_live.mjs",
    "test:live:marketing": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.runtime.local scripts/test_marketing_answer_ui_live.mjs",
    "test:live:brainstorm": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.runtime.local scripts/test_brainstorm_followup_ui_live.mjs",
    "test:live:workflow-commands": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.runtime.local scripts/test_workflow_commands_live.mjs",
    "poc": "node scripts/realityrank_poc.mjs",
    "test:outcomes": "vitest run tests/outcomes.test.js tests/outcomeEvidence.test.js tests/marketplaceRatingIdentity.test.js tests/runtimeAdoption.test.js",
    "poc:test": "npm run test:outcomes"
  },
  "dependencies": {
    "@clerk/express": "^2.1.40",
    "@clerk/react": "^6.12.2",
    "@clerk/shared": "^4.25.2",
    "@vitejs/plugin-react": "^6.0.3",
    "express": "^4.19.2",
    "katex": "^0.17.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "pdfjs-dist": "5.6.205",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.9.1",
    "@napi-rs/canvas": "^0.1.100",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.9.0",
    "supertest": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
