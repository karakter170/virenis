{
  "name": "virenis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server/index.js",
    "dev:tcar": "node --env-file-if-exists=.env.local server/index.js",
    "dev:vllm": "node --env-file-if-exists=.env.local server/index.js",
    "runtime:vllm": "node --env-file-if-exists=.env.local server/vllmRuntimeAdapter.js",
    "start": "NODE_ENV=production node server/index.js",
    "start:hosted": "NODE_ENV=production node server/hostedStart.js",
    "start:remote": "NODE_ENV=production node --env-file=.env.remote.local server/hostedStart.js",
    "tunnel:tcar": "node --env-file=.env.remote.local scripts/runtimeTunnel.mjs",
    "preflight:remote": "NODE_ENV=production node --env-file=.env.remote.local scripts/remotePreflight.mjs",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "marketing:router-quality": "node marketing/router-quality-showcase/render.mjs",
    "poc": "node scripts/realityrank_poc.mjs",
    "poc:test": "node fixtures/realityrank_poc_simulator.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "express": "^4.19.2",
    "katex": "^0.17.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "pdfjs-dist": "5.6.205",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@napi-rs/canvas": "^0.1.100",
    "eslint": "^9.9.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.9.0",
    "supertest": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
