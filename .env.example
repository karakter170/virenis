NODE_ENV=production
HOST=127.0.0.1
PORT=5173
# These defaults cover the 15-minute chat/validation runtime budget plus drain
# and process-close grace. Keep shutdown >= background drain.
APP_BACKGROUND_DRAIN_TIMEOUT_MS=930000
APP_ACCOUNT_DELETION_DRAIN_TIMEOUT_MS=5000
APP_ACCOUNT_DELETION_RECOVERY_INTERVAL_MS=60000
APP_ACCOUNT_DELETION_RECOVERY_BATCH=25
APP_SHUTDOWN_TIMEOUT_MS=960000
# Remote production databases should use certificate and hostname verification.
DATABASE_URL=postgres://tcar_app:replace-with-password@postgres.example.com:5432/tcar_app?sslmode=verify-full
WEB_ALLOW_INSECURE_PRIVATE_POSTGRES=0
WEB_STORE_DRIVER=postgres
WEB_DB_TABLE=tcar_app_store
WEB_DB_STORE_KEY=production
WEB_DB_READINESS_TIMEOUT_MS=5000
WEB_DB_CONNECT_TIMEOUT_MS=5000
# PostgreSQL cancels slightly before this client-side fail-safe deadline.
WEB_DB_QUERY_TIMEOUT_MS=5000
WEB_NORMALIZED_LEDGER_REQUIRED=1
WEB_NORMALIZED_BILLING_REQUIRED=1
WEB_PREFLIGHT_CURL_CONNECT_TIMEOUT_SEC=5
WEB_PREFLIGHT_CURL_MAX_TIME_SEC=15

# Credit billing. Persisted amounts use integer microcredits. Environment rates
# seed the first immutable pricing version; use the admin UI for later changes.
APP_BILLING_WELCOME_CREDITS=1000
APP_BILLING_PROMPT_CREDITS_PER_1K=0.10
APP_BILLING_COMPLETION_CREDITS_PER_1K=0.20
APP_BILLING_CACHED_CREDITS_PER_1K=0.02
APP_BILLING_UNCLASSIFIED_CREDITS_PER_1K=0.20
APP_BILLING_MINIMUM_RESERVATION_CREDITS=0.10
# Durable active-run reservations enforce these caps atomically.
APP_MAX_ACTIVE_RUNS_PER_USER=2
APP_MAX_ACTIVE_RUNS_PER_WORKSPACE=8
APP_MAX_ACTIVE_RUNS_GLOBAL=16

# simulator: local deterministic demo/runtime tests
# real: call the GPU Agent Runtime API configured below
AGENT_RUNTIME_MODE=real
AGENT_RUNTIME_API_URL=https://gpu-runtime.example.com
# Inline values take precedence. Prefer the mode-0600 file variant when the
# process manager or host can mount secrets as files.
AGENT_RUNTIME_API_KEY=replace-with-a-long-random-shared-secret
AGENT_RUNTIME_API_KEY_FILE=
AGENT_RUNTIME_HEALTH_TIMEOUT_MS=5000
AGENT_RUNTIME_AGENT_LIST_TIMEOUT_MS=120000
AGENT_RUNTIME_CHAT_TIMEOUT_MS=900000
# After a broken event stream, poll only for the already-claimed terminal
# result. This never starts a second model execution.
AGENT_RUNTIME_TERMINAL_RECOVERY_MS=90000
AGENT_RUNTIME_WORKFLOW_TIMEOUT_MS=900000
AGENT_RUNTIME_CONTINUATION_TIMEOUT_MS=900000
AGENT_RUNTIME_ADMIN_TIMEOUT_MS=600000
AGENT_RUNTIME_VALIDATION_TIMEOUT_SEC=900
AGENT_RUNTIME_ALLOW_LOCAL_RUNTIME_URL=0
# Set to 1 only when AGENT_RUNTIME_API_URL is a loopback listener maintained by
# a supervised SSH/VPN tunnel to the GPU host.
AGENT_RUNTIME_ALLOW_LOOPBACK_RUNTIME_TUNNEL=0
AGENT_RUNTIME_ALLOW_SAME_ORIGIN_RUNTIME_URL=0
AGENT_RUNTIME_ALLOW_INSECURE_PRIVATE_RUNTIME_HTTP=0

# MCP credentials are encrypted in the application store with this independent
# key. Prefer the mode-0600 file form in production. The gateway key is shared
# only with the protected Runtime process; it authorizes executor callbacks,
# not end users or remote MCP servers.
APP_MCP_CREDENTIAL_KEY=replace-with-a-different-long-random-encryption-secret
APP_MCP_CREDENTIAL_KEY_FILE=
APP_MCP_GATEWAY_KEY=replace-with-a-long-random-runtime-gateway-secret
APP_MCP_GATEWAY_KEY_FILE=
APP_MCP_TIMEOUT_MS=15000
APP_MCP_DNS_TIMEOUT_MS=5000
# Managed OAuth connections. Notion and Linear register automatically once
# this public HTTPS origin is configured. Google, GitHub, and Slack use the
# server-owned OAuth applications configured below; users never enter secrets.
APP_MCP_OAUTH_REDIRECT_ORIGIN=https://app.example.com
APP_MCP_OAUTH_TIMEOUT_MS=15000
# Crash recovery promotes incomplete OAuth exchanges, refreshes, and approved
# provider actions to explicit uncertainty after this grace. The server enforces
# a minimum of 20 minutes. Recovery is fair, bounded, and uses durable backoff.
APP_MCP_OAUTH_RECOVERY_GRACE_MS=1200000
APP_MCP_OAUTH_RECOVERY_INTERVAL_MS=60000
APP_MCP_OAUTH_RECOVERY_BATCH=25
# A continuation claim is durable in Postgres. This lease permits recovery
# after a web-process crash without ever repeating the approved MCP action.
# Must exceed the Runtime continuation timeout; the server enforces a 30s grace.
WORKFLOW_CONTINUATION_CLAIM_TTL_MS=930000
# Register one callback per enabled Google service:
# /api/mcp/oauth/callback/gmail
# /api/mcp/oauth/callback/google_drive
# /api/mcp/oauth/callback/google_calendar
# /api/mcp/oauth/callback/google_chat
# /api/mcp/oauth/callback/google_contacts
APP_MCP_GOOGLE_OAUTH_CLIENT_ID=
APP_MCP_GOOGLE_OAUTH_CLIENT_SECRET=
APP_MCP_GOOGLE_OAUTH_CLIENT_SECRET_FILE=
# Legacy Gmail-only variables remain supported during migration.
APP_MCP_GMAIL_OAUTH_CLIENT_ID=
APP_MCP_GMAIL_OAUTH_CLIENT_SECRET=
APP_MCP_GMAIL_OAUTH_CLIENT_SECRET_FILE=
# Register /api/mcp/oauth/callback/github in the GitHub OAuth/GitHub App.
APP_MCP_GITHUB_OAUTH_CLIENT_ID=
APP_MCP_GITHUB_OAUTH_CLIENT_SECRET=
APP_MCP_GITHUB_OAUTH_CLIENT_SECRET_FILE=
# Register /api/mcp/oauth/callback/slack in the Slack app.
APP_MCP_SLACK_OAUTH_CLIENT_ID=
APP_MCP_SLACK_OAUTH_CLIENT_SECRET=
APP_MCP_SLACK_OAUTH_CLIENT_SECRET_FILE=

AGENT_RUNTIME_PLANNER_MAX_TOKENS=768
AGENT_RUNTIME_MAX_ROUTING_AGENTS=16
AGENT_RUNTIME_PARALLEL_WORKERS=2
AGENT_RUNTIME_MAX_TOKENS=4096
AGENT_RUNTIME_REFINER_MAX_TOKENS=8192
AGENT_RUNTIME_TEMPERATURE=0
AGENT_RUNTIME_CLIENT_MAX_PLANNER_TOKENS=4096
AGENT_RUNTIME_CLIENT_MAX_ROUTING_AGENTS=16
AGENT_RUNTIME_CLIENT_MAX_PARALLEL_WORKERS=4
AGENT_RUNTIME_CLIENT_MAX_TOKENS=8192
AGENT_RUNTIME_CLIENT_MAX_REFINER_TOKENS=12288
AGENT_RUNTIME_CLIENT_MAX_TEMPERATURE=1
# Output ceilings are derived from these context reservations. Keep the values
# aligned with the active execution and orchestration model deployments.
AGENT_RUNTIME_MODEL_CONTEXT_TOKENS=32768
AGENT_RUNTIME_ORCHESTRATION_MODEL_CONTEXT_TOKENS=32768
AGENT_RUNTIME_ROUTE_INPUT_MAX_TOKENS=8192
AGENT_RUNTIME_REFINER_INPUT_MAX_TOKENS=16384
AGENT_RUNTIME_ROUTE_MIN_INPUT_TOKENS=8192
AGENT_RUNTIME_REFINER_MIN_INPUT_TOKENS=16384
AGENT_RUNTIME_ROUTE_TOKEN_SAFETY_MARGIN=128
AGENT_RUNTIME_COMPLETION_TOKEN_SAFETY_MARGIN=192
AGENT_RUNTIME_COMPACT_ROUTE_PROMPTS=1
AGENT_RUNTIME_SKILL_PROMPT_MAX_CHARS=2000
AGENT_RUNTIME_SOURCE_PROMPT_MAX_CHARS=6000
AGENT_RUNTIME_RETRIEVED_CONTEXT_MAX_CHARS=12000

API_RATE_WINDOW_MS=60000
API_RATE_LIMIT=600
API_RATE_MAX_BUCKETS=10000
# Run-event SSE connections are bounded independently from request rate limits.
# Streams send a proxy-safe heartbeat and are intentionally recycled so stale
# browser tabs cannot retain server resources forever.
APP_SSE_MAX_STREAMS_GLOBAL=500
APP_SSE_MAX_STREAMS_PER_IDENTITY=8
APP_SSE_HEARTBEAT_MS=15000
APP_SSE_MAX_LIFETIME_MS=960000
WEB_LIST_DEFAULT_LIMIT=100
WEB_LIST_MAX_LIMIT=500
APP_MAX_JSON_BODY_BYTES=1048576
APP_MAX_UPLOAD_FILE_BYTES=15728640
APP_MAX_UPLOAD_FIELD_BYTES=65536
APP_MAX_UPLOAD_FIELDS=20
APP_MAX_UPLOAD_PARTS=24
APP_MAX_DOCUMENT_TEXT_CHARS=2000000
APP_MAX_DOCUMENT_PDF_PAGES=500
APP_PDF_EXTRACTION_TIMEOUT_MS=60000
APP_MAX_DOCUMENT_CHUNKS=1000
APP_MAX_DOCUMENTS_PER_USER=50
APP_MAX_DOCUMENTS_PER_WORKSPACE=200
APP_MAX_SOURCE_TEXT_CHARS=200000
APP_MAX_MESSAGE_ATTACHMENTS=5
APP_MAX_MESSAGE_ATTACHMENT_CHARS=2000
AGENT_RUNTIME_SHARED_MEMORY_MAX_ENTRIES=40
AGENT_RUNTIME_SHARED_MEMORY_MAX_ENTRY_CHARS=2000
AGENT_RUNTIME_SHARED_MEMORY_MAX_TOTAL_CHARS=20000
APP_TRUST_PROXY=loopback
# Set to 1 only if readiness should fail when the private GPU runtime is down.
WEB_READY_REQUIRE_RUNTIME=0
# Set to 1 only for private/internal probes that may see aggregate store counts.
WEB_READY_INCLUDE_STORE_COUNTS=0

# Clerk browser identity. The publishable key is safe for the Vite bundle; keep
# secret and webhook keys server-only. Every account receives a private Virenis
# workspace. Organizations and shared membership are intentionally disabled.
APP_IDENTITY_PROVIDER=clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_live_replace-with-clerk-publishable-key
CLERK_PUBLISHABLE_KEY=pk_live_replace-with-clerk-publishable-key
CLERK_SECRET_KEY=
CLERK_SECRET_KEY_FILE=/run/secrets/virenis_clerk_secret_key
CLERK_WEBHOOK_SIGNING_SECRET=
CLERK_WEBHOOK_SIGNING_SECRET_FILE=/run/secrets/virenis_clerk_webhook_signing_secret
CLERK_AUTHORIZED_PARTIES=https://app.example.com
APP_AUTH_ADMIN_EMAILS=admin@your-domain.example
APP_CLERK_ADMIN_USER_IDS=

# Basic Auth remains optional break-glass access; bearer tokens are for API
# clients and probes. Production startup rejects missing/placeholder auth unless
# APP_ALLOW_UNAUTHENTICATED=1.
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASSWORD=
APP_BASIC_AUTH_PASSWORD_FILE=
APP_DEFAULT_WORKSPACE_ID=workspace_default
# JSON bearer identities may include up to 32 resolver_bindings. Only an admin
# bearer whose binding matches the frozen resolver may verify ranking evidence.
# A binding has type + authority and exactly one of reference or
# reference_prefix (prefixes are 8..1000 characters).
# Example identity: {"user_id":"oracle","workspace_id":"workspace_default","role":"admin","resolver_bindings":[{"type":"api","authority":"Signed outcomes","reference_prefix":"outcome:2026:"}]}
APP_API_TOKENS_JSON=
# Example APP_API_TOKENS entry: token:user_id:workspace_id:role
# Compact tokens cannot carry resolver bindings and are tracking-only settlers.
APP_API_TOKENS=
# Default 3; integer 1..100. Lower only for a controlled POC/test environment.
VIRENIS_REALITY_RANK_MIN_VERIFIED_SAMPLES=3
APP_PUBLIC_ORIGIN=https://app.example.com
APP_ALLOW_MISSING_PUBLIC_ORIGIN=0
APP_ALLOW_MISSING_ORIGIN=0
APP_ALLOW_SAME_SITE_FETCH=0
APP_ENABLE_HSTS=1
APP_ALLOW_JSON_STORE=0
# Set to 1 only for a deliberately unauthenticated public deployment.
APP_ALLOW_UNAUTHENTICATED=0
# Required only when APP_ALLOW_UNAUTHENTICATED=1; cannot be the local defaults.
APP_UNAUTHENTICATED_USER_ID=
APP_UNAUTHENTICATED_WORKSPACE_ID=
APP_UNAUTHENTICATED_ROLE=user
APP_ALLOW_PUBLIC_BIND=0
