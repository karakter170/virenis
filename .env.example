NODE_ENV=production
HOST=127.0.0.1
PORT=5173
APP_SHUTDOWN_TIMEOUT_MS=30000
DATABASE_URL=postgres://tcar_app:replace-with-password@postgres.example.com:5432/tcar_app
WEB_STORE_DRIVER=postgres
WEB_DB_TABLE=tcar_app_store
WEB_DB_STORE_KEY=production

# simulator: local deterministic demo/runtime tests
# real: call the GPU TCAR Runtime API configured below
TCAR_ENGINE_MODE=real
TCAR_RUNTIME_API_URL=https://gpu-runtime.example.com
TCAR_RUNTIME_API_KEY=replace-with-a-long-random-shared-secret
TCAR_RUNTIME_HEALTH_TIMEOUT_MS=5000
TCAR_RUNTIME_CHAT_TIMEOUT_MS=900000
TCAR_RUNTIME_ADMIN_TIMEOUT_MS=600000
TCAR_RUNTIME_VALIDATION_TIMEOUT_SEC=900
TCAR_ALLOW_LOCAL_RUNTIME_URL=0
TCAR_ALLOW_SAME_ORIGIN_RUNTIME_URL=0

TCAR_PLANNER_MODE=tcandon
TCAR_MAX_ROUTING_ADAPTERS=12
TCAR_PARALLEL_WORKERS=2
TCAR_MAX_TOKENS=512
TCAR_REFINER_MAX_TOKENS=768
TCAR_TEMPERATURE=0
TCAR_CLIENT_MAX_PLANNER_TOKENS=512
TCAR_CLIENT_MAX_ROUTING_ADAPTERS=24
TCAR_CLIENT_MAX_PARALLEL_WORKERS=4
TCAR_CLIENT_MAX_TOKENS=512
TCAR_CLIENT_MAX_REFINER_TOKENS=1024
TCAR_CLIENT_MAX_TEMPERATURE=1
TCAR_COMPACT_ROUTE_PROMPTS=1
TCAR_SKILL_PROMPT_MAX_CHARS=650
TCAR_SOURCE_PROMPT_MAX_CHARS=1200
TCAR_RETRIEVED_CONTEXT_MAX_CHARS=700

API_RATE_WINDOW_MS=60000
API_RATE_LIMIT=600
API_RATE_MAX_BUCKETS=10000
WEB_LIST_DEFAULT_LIMIT=100
WEB_LIST_MAX_LIMIT=500
APP_MAX_JSON_BODY_BYTES=1048576
APP_MAX_UPLOAD_FILE_BYTES=15728640
APP_MAX_UPLOAD_FIELD_BYTES=65536
APP_MAX_UPLOAD_FIELDS=20
APP_MAX_UPLOAD_PARTS=24
APP_MAX_DOCUMENT_TEXT_CHARS=2000000
APP_MAX_DOCUMENT_CHUNKS=1000
APP_MAX_DOCUMENTS_PER_USER=50
APP_MAX_DOCUMENTS_PER_WORKSPACE=200
APP_MAX_SOURCE_TEXT_CHARS=200000
APP_MAX_MESSAGE_ATTACHMENTS=5
APP_MAX_MESSAGE_ATTACHMENT_CHARS=2000
TCAR_SHARED_MEMORY_MAX_ENTRIES=40
TCAR_SHARED_MEMORY_MAX_ENTRY_CHARS=2000
TCAR_SHARED_MEMORY_MAX_TOTAL_CHARS=20000
APP_TRUST_PROXY=loopback
# Set to 1 only if readiness should fail when the private GPU runtime is down.
WEB_READY_REQUIRE_RUNTIME=0
# Set to 1 only for private/internal probes that may see aggregate store counts.
WEB_READY_INCLUDE_STORE_COUNTS=0

# Configure either Basic Auth for browser/admin access, bearer tokens for API
# clients, or both. Production startup rejects missing/placeholder auth unless
# APP_ALLOW_UNAUTHENTICATED=1.
APP_BASIC_AUTH_USER=admin
APP_BASIC_AUTH_PASSWORD=replace-with-a-long-random-password
APP_DEFAULT_WORKSPACE_ID=workspace_default
APP_API_TOKENS_JSON=
# Example APP_API_TOKENS entry: token:user_id:workspace_id:role
APP_API_TOKENS=
APP_PUBLIC_ORIGIN=https://app.example.com
APP_ALLOW_MISSING_PUBLIC_ORIGIN=0
APP_ALLOW_MISSING_ORIGIN=0
APP_ALLOW_SAME_SITE_FETCH=0
APP_ENABLE_HSTS=1
APP_ALLOW_JSON_STORE=0
# Set to 1 only for a deliberately unauthenticated public deployment.
APP_ALLOW_UNAUTHENTICATED=0
# Required only when APP_ALLOW_UNAUTHENTICATED=1; cannot be the local defaults.
APP_UNAUTHENTICATED_USER_ID=
APP_UNAUTHENTICATED_WORKSPACE_ID=
APP_UNAUTHENTICATED_ROLE=user
APP_ALLOW_PUBLIC_BIND=0
